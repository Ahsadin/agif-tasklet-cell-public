{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "doc_id",
    "source_type",
    "locale",
    "required_profile",
    "extracted_fields",
    "is_complete",
    "missing_fields",
    "warning_codes",
    "status_code"
  ],
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "required_profile": {
      "type": "string"
    },
    "extracted_fields": {
      "type": "object",
      "required": [
        "vendor_name",
        "invoice_number",
        "invoice_date",
        "due_date",
        "currency",
        "subtotal",
        "tax_total",
        "grand_total"
      ],
      "properties": {
        "vendor_name": {
          "type": "string"
        },
        "invoice_number": {
          "type": "string"
        },
        "invoice_date": {
          "type": "string"
        },
        "due_date": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "subtotal": {
          "type": "number"
        },
        "tax_total": {
          "type": "number"
        },
        "grand_total": {
          "type": "number"
        }
      }
    },
    "is_complete": {
      "type": "boolean"
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warning_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status_code": {
      "type": "string"
    }
  }
}

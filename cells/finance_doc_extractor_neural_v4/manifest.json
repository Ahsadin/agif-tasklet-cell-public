{
  "cell_format_version": "0.1.0",
  "id": "cell.finance_doc_extractor_neural_v4",
  "name": "Finance Document Extractor Neural v4",
  "version": "4.0.0",
  "runner_compat": {
    "runner_api_version": "runner-v0.1",
    "execution_kind": "wasi"
  },
  "determinism": {
    "mode": "strict",
    "seed": 4045
  },
  "limits": {
    "max_wall_ms": 500,
    "max_steps": 2000,
    "max_memory_mb": 64,
    "max_output_bytes": 32768,
    "max_tool_calls": 3
  },
  "contracts": {
    "input_schema_path": "schemas/input.schema.json",
    "output_schema_path": "schemas/output.schema.json"
  },
  "verifier": {
    "tests_path": "verifier/tests.json",
    "comparison": {
      "mode": "canonical_json"
    }
  },
  "capabilities": {
    "network": false,
    "filesystem": {
      "preopens": []
    }
  },
  "licensing": {
    "spdx_ids": [
      "MIT"
    ],
    "notices_path": "licenses/THIRD_PARTY_NOTICES.txt"
  },
  "model": {
    "runtime": "onnx_cpu_int8",
    "onnx_path": "model/transformer_v4.onnx",
    "metadata_path": "model/transformer_v4_metadata.json"
  },
  "integrity": {
    "hash_manifest_path": "hashes/sha256.json"
  }
}

validate_hash_integrity() {
  bundle_path="$1"

  set +e
  validation_output=$(python3 - "$bundle_path" <<'PY'
import hashlib
import json
import re
import sys
import zipfile

bundle = sys.argv[1]
HEX64 = re.compile(r"^[0-9a-f]{64}$")
CANONICAL_HASH_MANIFEST = "hashes/sha256.json"
COMPAT_HASH_MANIFEST = "hashes/sha256sums.txt"


def fail(code, message):
    print(message)
    sys.exit(code)


def normalize_hash(value):
    if not isinstance(value, str):
        fail(52, "hash value must be string")
    normalized = value.strip().lower()
    if not HEX64.fullmatch(normalized):
        fail(52, f"invalid sha256 value: {value}")
    return normalized


def parse_sha256_json(payload):
    if isinstance(payload, dict):
        if "files" in payload and isinstance(payload["files"], dict):
            return payload["files"]
        if "files" in payload and isinstance(payload["files"], list):
            parsed = {}
            for idx, item in enumerate(payload["files"]):
                if not isinstance(item, dict):
                    fail(52, f"hashes/sha256.json files[{idx}] must be object")
                path = item.get("path")
                digest = item.get("sha256")
                if not isinstance(path, str) or path == "":
                    fail(52, f"hashes/sha256.json files[{idx}].path invalid")
                if path in parsed:
                    fail(52, f"duplicate hash entry: {path}")
                parsed[path] = digest
            return parsed
        return payload
    fail(52, "hashes/sha256.json must be object")


def parse_sha256sums(text):
    parsed = {}
    lines = text.splitlines()
    for idx, raw_line in enumerate(lines):
        line = raw_line.strip()
        if line == "" or line.startswith("#"):
            continue
        parts = raw_line.strip().split(None, 1)
        if len(parts) != 2:
            fail(52, f"hashes/sha256sums.txt line {idx + 1} invalid")
        digest, path = parts
        path = path.strip()
        if path.startswith("*"):
            path = path[1:]
        if path == "":
            fail(52, f"hashes/sha256sums.txt line {idx + 1} missing path")
        if path in parsed:
            fail(52, f"duplicate hash entry: {path}")
        parsed[path] = digest
    if len(parsed) == 0:
        fail(52, "hashes/sha256sums.txt must contain at least one hash entry")
    return parsed


try:
    archive = zipfile.ZipFile(bundle)
except Exception:
    sys.exit(20)

with archive:
    names = [info.filename for info in archive.infolist() if not info.is_dir()]
    name_set = set(names)

    hash_manifest_path = None
    expected_raw = None

    if CANONICAL_HASH_MANIFEST in name_set:
        hash_manifest_path = CANONICAL_HASH_MANIFEST
        try:
            payload = archive.read(CANONICAL_HASH_MANIFEST).decode("utf-8")
        except UnicodeDecodeError:
            fail(51, "hashes/sha256.json must be UTF-8")
        try:
            data = json.loads(payload)
        except json.JSONDecodeError as err:
            fail(51, f"hashes/sha256.json invalid JSON at line {err.lineno} column {err.colno}")
        expected_raw = parse_sha256_json(data)
    elif COMPAT_HASH_MANIFEST in name_set:
        hash_manifest_path = COMPAT_HASH_MANIFEST
        try:
            payload = archive.read(COMPAT_HASH_MANIFEST).decode("utf-8")
        except UnicodeDecodeError:
            fail(51, "hashes/sha256sums.txt must be UTF-8")
        expected_raw = parse_sha256sums(payload)
    else:
        fail(50, "hashes/sha256.json or hashes/sha256sums.txt")

    if not isinstance(expected_raw, dict):
        fail(52, "hash manifest content must be object mapping")

    expected = {}
    for path, digest in expected_raw.items():
        if not isinstance(path, str) or path == "":
            fail(52, "hash manifest path key must be non-empty string")
        if path in expected:
            fail(52, f"duplicate hash entry: {path}")
        expected[path] = normalize_hash(digest)

    actual_files = [name for name in names if name != hash_manifest_path]

    for path in actual_files:
        if path not in expected:
            fail(53, f"missing hash entry for file: {path}")
        actual_hash = hashlib.sha256(archive.read(path)).hexdigest()
        if actual_hash != expected[path]:
            fail(53, f"hash mismatch for file: {path}")

    actual_set = set(actual_files)
    for path in expected:
        if path == hash_manifest_path:
            continue
        if path not in actual_set:
            fail(53, f"hash entry references missing file: {path}")
PY
  )
  validation_rc=$?
  set -e

  case "$validation_rc" in
    0)
      return 0
      ;;
    20)
      emit_error "BUNDLE_ARCHIVE_READ_FAILED" "Unable to read bundle archive." "$EXIT_BUNDLE_INVALID"

        support = float(ref.get("support"))
        if support < 0.0 or support > 1.0:
            return f"output.evidence_refs[{idx}].support must be in range [0,1]"

    return None


def resolve_wasmtime_executable():
    env_bin = os.environ.get("AGIF_WASMTIME_BIN", "").strip()
    if env_bin != "":
        return env_bin
    auto = shutil.which("wasmtime")
    if auto is not None and auto.strip() != "":
        return auto
    home_candidate = os.path.expanduser("~/.wasmtime/bin/wasmtime")
    if os.path.isfile(home_candidate):
        return home_candidate
    return "wasmtime"


def build_wasmtime_run_command(fuel_limit, max_memory_mb):
    wasmtime_bin = resolve_wasmtime_executable()
    cmd = [wasmtime_bin, "run"]
    fuel_flag_applied = False
    memory_flag_applied = False
    try:
        help_proc = subprocess.run(
            [wasmtime_bin, "run", "--help"],
            capture_output=True,
            text=True,
            check=False,
        )
        help_text = (help_proc.stdout or "") + (help_proc.stderr or "")
        if "--fuel" in help_text:
            cmd.extend(["--fuel", str(int(fuel_limit))])
            fuel_flag_applied = True
        if "max-memory-size" in help_text:
            cmd.extend(["-W", f"max-memory-size={int(max_memory_mb) * 1024 * 1024}"])
            memory_flag_applied = True
    except Exception:
        pass
    return cmd, fuel_flag_applied, memory_flag_applied


def classify_wasmtime_failure(stderr_text, stdout_text):
    combined = f"{stderr_text}\n{stdout_text}".lower()
    if "fuel" in combined and ("consumed" in combined or "exhaust" in combined or "remaining fuel 0" in combined):
        return {"kind": "limit", "code": "FUEL_LIMIT_EXCEEDED", "message": "wasmtime fuel limit exceeded"}
    if "memory" in combined and (
        "out of bounds" in combined
        or "maximum memory size" in combined
        or "cannot grow memory" in combined
        or "allocation" in combined
    ):
        return {"kind": "limit", "code": "MEMORY_LIMIT_EXCEEDED", "message": "wasmtime memory limit exceeded"}
    return {"kind": "runtime", "code": "WASMTIME_TRAP", "message": "wasmtime runtime trap"}


def run_v6_wasmtime_inference(logic_wasm_bytes, request_payload, max_wall_ms, fuel_limit, max_memory_mb):
    request_json = json.dumps(request_payload, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
    started = time.monotonic()
    tmp_path = None
    try:
        with tempfile.NamedTemporaryFile(delete=False, suffix=".wasm") as wasm_file:
            wasm_file.write(logic_wasm_bytes)
            tmp_path = wasm_file.name

        base_cmd, fuel_flag_applied, memory_flag_applied = build_wasmtime_run_command(fuel_limit, max_memory_mb)
        command = base_cmd + [tmp_path]
        try:
            proc = subprocess.run(
                command,
                input=request_json,
                capture_output=True,
                text=True,
                timeout=max(float(max_wall_ms) / 1000.0, 0.001),
                check=False,
            )
        except FileNotFoundError:
            return None, None, {"kind": "runtime", "code": "WASMTIME_UNAVAILABLE", "message": "wasmtime executable not found"}
        except subprocess.TimeoutExpired:
            return None, None, {"kind": "limit", "code": "WALL_TIMEOUT_EXCEEDED", "message": "wasmtime execution timeout"}

        elapsed_ms = int((time.monotonic() - started) * 1000)
        stdout_text = (proc.stdout or "").strip()
        stderr_text = (proc.stderr or "").strip()
        if proc.returncode != 0:
            error = classify_wasmtime_failure(stderr_text, stdout_text)
            error["message"] = f"{error['message']} (code {proc.returncode})"
            return None, None, error
        if stdout_text == "":
            return None, None, {"kind": "runtime", "code": "WASMTIME_OUTPUT_EMPTY", "message": "wasmtime run returned empty stdout"}
        try:
            payload = json.loads(stdout_text)
        except json.JSONDecodeError as err:
            return None, None, {
                "kind": "runtime",
                "code": "WASMTIME_OUTPUT_INVALID",
                "message": f"wasmtime stdout invalid JSON at line {err.lineno} column {err.colno}",
            }
        if not isinstance(payload, dict):
            return None, None, {"kind": "runtime", "code": "WASMTIME_OUTPUT_INVALID", "message": "wasmtime stdout must be JSON object"}
        details = {
            "elapsed_ms": elapsed_ms,
            "fuel_flag_applied": fuel_flag_applied,
            "memory_flag_applied": memory_flag_applied,
            "command": command,
        }
        return payload, details, None
    finally:
        if tmp_path is not None:
            try:
                os.unlink(tmp_path)
            except Exception:
                pass


def to_signed_int8(byte_value):
    if byte_value > 127:
        return byte_value - 256
    return byte_value


def load_runtime_weight_pack():
    fallback_seed_material = f"{logic_wasm_hash}|{manifest.get('id','')}"
    fallback_seed = hashlib.sha256(fallback_seed_material.encode("utf-8")).digest()

    model_bin_path = os.environ.get("AGIF_RUNTIME_MODEL_BIN", "").strip()
    if model_bin_path != "" and os.path.isfile(model_bin_path):
        try:
            raw = open(model_bin_path, "rb").read()
        except Exception:
            raw = b""
        if len(raw) >= 21:
            runtime_profile["runtime_model_hash"] = hashlib.sha256(raw).hexdigest()
            runtime_profile["runtime_model_source"] = "env_model_bin"
            values = [to_signed_int8(b) for b in raw[:21]]
            return {
                "weights": [
                    [float(values[0]) / 64.0, float(values[1]) / 64.0, float(values[2]) / 64.0, float(values[3]) / 64.0, float(values[4]) / 64.0, float(values[5]) / 64.0],
                    [float(values[6]) / 64.0, float(values[7]) / 64.0, float(values[8]) / 64.0, float(values[9]) / 64.0, float(values[10]) / 64.0, float(values[11]) / 64.0],
                    [float(values[12]) / 64.0, float(values[13]) / 64.0, float(values[14]) / 64.0, float(values[15]) / 64.0, float(values[16]) / 64.0, float(values[17]) / 64.0],
                ],
                "bias": [
                    float(values[18]) / 32.0,
                    float(values[19]) / 32.0,
                    float(values[20]) / 32.0,
                ],
            }

    runtime_profile["runtime_model_hash"] = logic_wasm_hash if logic_wasm_hash != "" else ""
    runtime_profile["runtime_model_source"] = "fallback_logic_wasm"
    values = [to_signed_int8(b) for b in fallback_seed[:21]]
    return {
        "weights": [
            [float(values[0]) / 80.0, float(values[1]) / 80.0, float(values[2]) / 80.0, float(values[3]) / 80.0, float(values[4]) / 80.0, float(values[5]) / 80.0],
            [float(values[6]) / 80.0, float(values[7]) / 80.0, float(values[8]) / 80.0, float(values[9]) / 80.0, float(values[10]) / 80.0, float(values[11]) / 80.0],
            [float(values[12]) / 80.0, float(values[13]) / 80.0, float(values[14]) / 80.0, float(values[15]) / 80.0, float(values[16]) / 80.0, float(values[17]) / 80.0],
        ],
        "bias": [
            float(values[18]) / 48.0,
            float(values[19]) / 48.0,
            float(values[20]) / 48.0,
        ],
    }


def parse_amount_token(token):
    value = token.strip()
    if value == "":
        return None
    if "," in value and "." in value:
        if value.rfind(",") > value.rfind("."):
            value = value.replace(".", "").replace(",", ".")
        else:
            value = value.replace(",", "")
    elif "," in value and "." not in value:
        value = value.replace(".", "").replace(",", ".")
    else:
        value = value.replace(",", "")
    try:
        return float(value)
    except Exception:
        return None


def detect_currency(ocr_text, currency_hint, locale):
    hint = currency_hint.strip().upper() if isinstance(currency_hint, str) else ""
    if len(hint) == 3:
        return hint
    upper_text = ocr_text.upper()
    if "EUR" in upper_text or "€" in ocr_text:
        return "EUR"
    if "USD" in upper_text or "$" in ocr_text:
        return "USD"
    if "GBP" in upper_text or "£" in ocr_text:
        return "GBP"
    if "CHF" in upper_text:
        return "CHF"
    locale_upper = locale.upper()
    if locale_upper.startswith("DE") or locale_upper.startswith("ES") or locale_upper.startswith("FR"):
        return "EUR"
    return "USD"


def normalize_iso_date(raw_value):
    value = raw_value.strip()
    if value == "":
        return None
    value = value.replace("/", "-")
    try:
        return datetime.strptime(value, "%Y-%m-%d").date().isoformat()
    except Exception:
        return None


def deterministic_date(doc_id, plus_days):
    base = date(2026, 1, 1)
    doc_hash = hashlib.sha256(doc_id.encode("utf-8")).hexdigest()
    offset = int(doc_hash[:8], 16) % 365
    return (base + timedelta(days=offset + plus_days)).isoformat()


def find_vendor_name(ocr_text, account_context):
    vendor_hint = account_context.get("vendor_hint")
    if isinstance(vendor_hint, str) and vendor_hint.strip() != "":
        return vendor_hint.strip()
    tokens = re.findall(r"[A-Za-z][A-Za-z0-9&.-]{1,}", ocr_text)
    stop = {"INVOICE", "RECEIPT", "TOTAL", "TAX", "VAT", "IVA", "FACTURA", "RECHNUNG"}
    for token in tokens:
        if token.upper() not in stop:
            return token.strip()
    return "Unknown Vendor"


def find_invoice_number(ocr_text):
    upper = ocr_text.upper()
    patterns = [
        r"\b[A-Z]{1,6}-\d{2,8}\b",
        r"\bINV[-\s]?\d{2,10}\b",
        r"\bV-\d{2,10}\b",
    ]
    for pattern in patterns:
        match = re.search(pattern, upper)
        if match is not None:
            return match.group(0).replace(" ", "")
    return ""


def extract_amounts(ocr_text):
    amount_pattern = r"[-+]?\d{1,3}(?:[.,]\d{3})*(?:[.,]\d{2})|[-+]?\d+(?:[.,]\d{2})"
    raw_tokens = re.findall(amount_pattern, ocr_text)
    values = []
    for token in raw_tokens:
        parsed = parse_amount_token(token)
        if parsed is not None:
            values.append(parsed)
    return values


def keyword_amount(upper_text, keyword_pattern):
    amount_pattern = r"[-+]?\d{1,3}(?:[.,]\d{3})*(?:[.,]\d{2})|[-+]?\d+(?:[.,]\d{2})"
    match = re.search(keyword_pattern + r"\s*[:=]?\s*(" + amount_pattern + r")", upper_text)
    if match is None:
        return None
    return parse_amount_token(match.group(1))


def _vendor_hint_from_input(input_value):
    if not isinstance(input_value, dict):
        return ""
    account_context = input_value.get("account_context")
    if isinstance(account_context, dict):
        vendor_hint = account_context.get("vendor_hint")
        if isinstance(vendor_hint, str) and vendor_hint.strip() != "":
            return vendor_hint.strip()
    extracted_fields = input_value.get("extracted_fields")
    if isinstance(extracted_fields, dict):
        vendor_name = extracted_fields.get("vendor_name")
        if isinstance(vendor_name, str) and vendor_name.strip() != "":
            return vendor_name.strip()
    return ""


def _normalize_memory_context(existing_context):
    normalized = {
        "session_window": [],
        "top_corrections": [],
        "vendor_profile": None,
        "warnings": [],
    }
    if not isinstance(existing_context, dict):
        return normalized

    existing_session = existing_context.get("session_window")
    if isinstance(existing_session, list):
        normalized["session_window"] = [entry for entry in existing_session if isinstance(entry, dict)][-10:]

    existing_top = existing_context.get("top_corrections")
    if isinstance(existing_top, list):
        normalized["top_corrections"] = [entry for entry in existing_top if isinstance(entry, dict)][:5]

    vendor_profile = existing_context.get("vendor_profile")
    if vendor_profile is None or isinstance(vendor_profile, dict):
        normalized["vendor_profile"] = vendor_profile

    existing_warnings = existing_context.get("warnings")
    if isinstance(existing_warnings, list):
        normalized["warnings"] = [str(item) for item in existing_warnings]

    return normalized


def enrich_input_with_memory(input_value):
    if not isinstance(input_value, dict):
        return input_value

    enriched = dict(input_value)
    memory_context = _normalize_memory_context(input_value.get("memory_context"))
    warning_list = list(memory_context.get("warnings", []))
    warning_list.extend([str(item) for item in memory_import_warnings])

    if len(memory_context["session_window"]) == 0 and session_memory is not None:
        try:
            memory_context["session_window"] = session_memory.get_context_window(10)
        except Exception as err:
            warning_list.append(f"session_window_read_failed:{err}")

    vendor_hint = _vendor_hint_from_input(input_value)
    if vendor_hint != "":
        if episodic_store is not None:
            try:
                memory_context["top_corrections"] = episodic_store.get_top_corrections(vendor_hint, n=5)
                memory_context["vendor_profile"] = episodic_store.get_vendor_profile(vendor_hint)
            except Exception as err:
                warning_list.append(f"episodic_read_failed:{err}")
        else:
            warning_list.append("episodic_store_unavailable")

    memory_context["warnings"] = warning_list
    enriched["memory_context"] = memory_context
    return enriched


def _coerce_like(current_value, incoming_value):
    if isinstance(current_value, bool):
        if isinstance(incoming_value, bool):
            return incoming_value
        incoming_text = str(incoming_value).strip().lower()
        if incoming_text in {"true", "1", "yes"}:
            return True
        if incoming_text in {"false", "0", "no"}:
            return False
        return current_value
    if isinstance(current_value, int) and not isinstance(current_value, bool):
        try:
            return int(float(incoming_value))
        except Exception:
            return current_value
    if isinstance(current_value, float):
        try:
            return float(incoming_value)
        except Exception:
            return current_value
    return str(incoming_value)


def apply_memory_corrections(extracted_fields, memory_context):
    if not isinstance(extracted_fields, dict) or not isinstance(memory_context, dict):
        return []
    top_corrections = memory_context.get("top_corrections")
    if not isinstance(top_corrections, list):
        return []
    applied = []
    for correction in top_corrections[:5]:
        if not isinstance(correction, dict):
            continue
        field_name = correction.get("field_name")
        if not isinstance(field_name, str) or field_name not in extracted_fields:
            continue
        if "correct_value" not in correction:
            continue
        before_value = extracted_fields.get(field_name)
        corrected_value = _coerce_like(before_value, correction.get("correct_value"))
        if corrected_value == before_value:
            continue
        extracted_fields[field_name] = corrected_value
        applied.append(
            {
                "field_name": field_name,
                "before_value": before_value,
                "correct_value": corrected_value,
            }
        )
    return applied


def softmax(scores):
    max_score = max(scores)
    exps = [math.exp(score - max_score) for score in scores]
    denom = sum(exps)
    if denom <= 0:
        return [1.0 / float(len(scores)) for _ in scores]
    return [value / denom for value in exps]


def build_routing_and_ranking(ocr_text, source_type, account_context, doc_id):
    upper = ocr_text.upper()
    ledger_profile = account_context.get("ledger_profile", "")
    features = [
        1.0 if any(token in upper for token in ("INVOICE", "FACTURA", "RECHNUNG", "BILL")) else 0.0,
        1.0 if any(token in upper for token in ("RECEIPT", "QUITTUNG", "TICKET")) else 0.0,
        1.0 if any(token in upper for token in ("TAX", "VAT", "IVA", "MWST")) else 0.0,
        1.0 if any(token in upper for token in ("TOTAL", "AMOUNT", "GESAMT", "IMPORTE")) else 0.0,
        1.0 if (str(source_type).lower() == "invoice" or "ap" in str(ledger_profile).lower()) else 0.0,
        1.0 if (str(source_type).lower() == "receipt" or "expense" in str(ledger_profile).lower()) else 0.0,
    ]

    weight_pack = load_runtime_weight_pack()
    weights = weight_pack["weights"]
    bias = weight_pack["bias"]
    labels = ["accounts_payable_invoice", "expense_receipt", "other_finance_doc"]

    raw_scores = []
    for row_idx in range(3):
        score = bias[row_idx]
        for col_idx in range(6):
            score += weights[row_idx][col_idx] * features[col_idx]
        tie_salt = hashlib.sha256(f"{doc_id}|{labels[row_idx]}".encode("utf-8")).digest()[0]
        score += float(tie_salt) / 1000000.0
        raw_scores.append(score)

    # Deterministic post-processing guardrails to keep routing stable on obvious patterns.
    if features[0] == 1.0 and features[3] == 1.0:
        raw_scores[0] += 1.5
    if features[4] == 1.0:
        raw_scores[0] += 0.5
    if features[1] == 1.0:
        raw_scores[1] += 1.2
    if features[5] == 1.0:
        raw_scores[1] += 0.5

    probs = softmax(raw_scores)
    ranking = []
    for idx, label in enumerate(labels):
        if label == "accounts_payable_invoice":
            reason = "invoice-focused tokens and context"
        elif label == "expense_receipt":
            reason = "receipt-focused tokens and context"
        else:
            reason = "fallback finance class"
        ranking.append({"candidate": label, "score": round(float(probs[idx]), 4), "reason": reason})
    ranking.sort(key=lambda row: (-row["score"], row["candidate"]))
    routing_label = ranking[0]["candidate"]
    confidence = float(ranking[0]["score"])
    return routing_label, confidence, ranking


def generate_extractor_output(input_value):
    if not isinstance(input_value, dict):
        return None, "input must be JSON object for extractor run"

    passthrough_keys = ("routing_label", "confidence", "extracted_fields", "warnings", "ranking")
    if all(key in input_value for key in passthrough_keys):
        runtime_profile["extractor_generation_mode"] = "passthrough"
        return input_value, None

    for key in ("doc_id", "source_type", "import_event", "ocr_text", "locale", "currency_hint"):
        value = input_value.get(key)
        if not isinstance(value, str) or value.strip() == "":
            return None, f"input.{key} must be non-empty string for runtime inference"

    account_context = input_value.get("account_context")
    if not isinstance(account_context, dict):
        return None, "input.account_context must be object for runtime inference"
    for key in ("ledger_profile", "cost_center"):
        value = account_context.get(key)
        if not isinstance(value, str) or value.strip() == "":
            return None, f"input.account_context.{key} must be non-empty string for runtime inference"

    doc_id = input_value["doc_id"].strip()
    source_type = input_value["source_type"].strip()
    import_event = input_value["import_event"].strip()
    ocr_text = input_value["ocr_text"].strip()
    locale = input_value["locale"].strip()
    currency_hint = input_value["currency_hint"].strip()

    routing_label, confidence, ranking = build_routing_and_ranking(ocr_text, source_type, account_context, doc_id)
    upper_text = ocr_text.upper()
    if source_type.lower() == "invoice" and any(token in upper_text for token in ("INVOICE", "FACTURA", "RECHNUNG")):
        routing_label = "accounts_payable_invoice"
        confidence = max(confidence, 0.9)
    elif source_type.lower() == "receipt" and any(token in upper_text for token in ("RECEIPT", "QUITTUNG", "TICKET")):
        routing_label = "expense_receipt"
        confidence = max(confidence, 0.9)

    ranking_map = {item["candidate"]: item for item in ranking if isinstance(item, dict) and "candidate" in item and "score" in item}
    if routing_label in ranking_map:
        ranking_map[routing_label]["score"] = round(float(max(ranking_map[routing_label]["score"], confidence)), 4)
    ranking = sorted(ranking_map.values(), key=lambda row: (-row["score"], row["candidate"]))

    currency = detect_currency(ocr_text, currency_hint, locale)
    vendor_name = find_vendor_name(ocr_text, account_context)
    invoice_number = find_invoice_number(ocr_text)

    amount_values = extract_amounts(ocr_text)
    grand_total = keyword_amount(upper_text, r"(TOTAL|AMOUNT DUE|GESAMT|IMPORTE)")
    tax_total = keyword_amount(upper_text, r"(TAX|VAT|IVA|MWST)")

    warnings = []
    if grand_total is None:
        if len(amount_values) > 0:
            grand_total = max(amount_values)
        else:
            grand_total = float((int(hashlib.sha256(doc_id.encode("utf-8")).hexdigest()[:6], 16) % 90000) / 100.0 + 100.0)
            warnings.append("totals_inferred_from_fallback")

    if tax_total is None:
        if any(token in upper_text for token in ("TAX", "VAT", "IVA", "MWST")) and len(amount_values) >= 2:
            tax_total = min(amount_values)
        else:
            tax_total = 0.0

    subtotal = grand_total - tax_total
    if subtotal < 0:
        subtotal = grand_total
        warnings.append("tax_total_exceeds_grand_total")

    normalized_dates = re.findall(r"\b20\d{2}[-/](?:0[1-9]|1[0-2])[-/](?:0[1-9]|[12]\d|3[01])\b", ocr_text)
    invoice_date = normalize_iso_date(normalized_dates[0]) if len(normalized_dates) > 0 else None
    if invoice_date is None:
        invoice_date = deterministic_date(doc_id, 0)
    if len(normalized_dates) > 1:
        due_date = normalize_iso_date(normalized_dates[1])
    else:
        due_date = None
    if due_date is None:
        try:
            due_date = (datetime.strptime(invoice_date, "%Y-%m-%d").date() + timedelta(days=30)).isoformat()
        except Exception:
            due_date = deterministic_date(doc_id, 30)

    if routing_label == "accounts_payable_invoice" and invoice_number == "":
        warnings.append("invoice_number_missing")
    if confidence < 0.55:
        warnings.append("low_confidence_routing")

    extracted_fields = {
        "vendor_name": vendor_name,
        "invoice_number": invoice_number,
        "invoice_date": invoice_date,
        "due_date": due_date,
        "currency": currency,
        "subtotal": round(float(subtotal), 2),
        "tax_total": round(float(tax_total), 2),
        "grand_total": round(float(grand_total), 2),
    }

    output = {
        "doc_id": doc_id,
        "source_type": source_type,
        "import_event": import_event,
        "ocr_text": ocr_text,
        "locale": locale,
        "currency_hint": currency_hint,
        "account_context": {
            "ledger_profile": account_context["ledger_profile"],
            "cost_center": account_context["cost_center"],
            "vendor_hint": account_context.get("vendor_hint", "") if isinstance(account_context.get("vendor_hint"), str) else "",
        },
        "routing_label": routing_label,
        "confidence": round(float(confidence), 4),
        "extracted_fields": extracted_fields,
        "warnings": warnings,
        "ranking": ranking,
    }
    runtime_profile["extractor_generation_mode"] = "generated"
    return output, None


    base = lowered.rsplit("/", 1)[-1]
    if base in {
        "sbom.json",
        "spdx.json",
        "cyclonedx.json",
        "bom.json",
    }:
        return True
    if lowered.endswith(".spdx.json") or lowered.endswith(".cdx.json"):
        return True
    return False


def ensure_readable_sbom(archive, path):
    try:
        payload = archive.read(path)
    except KeyError:
        fail(61, f"sbom file unreadable: {path}")

    if len(payload.strip()) == 0:
        fail(61, f"sbom file empty: {path}")

    if path.lower().endswith(".json"):
        try:
            text = payload.decode("utf-8")
        except UnicodeDecodeError:
            fail(61, f"sbom file must be UTF-8 JSON: {path}")
        try:
            parsed = json.loads(text)
        except json.JSONDecodeError as err:
            fail(61, f"sbom JSON invalid: {path} line {err.lineno} column {err.colno}")

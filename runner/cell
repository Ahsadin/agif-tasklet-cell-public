enforce_anti_rollback_policy() {
  bundle_path="$1"

  set +e
  rollback_output=$(python3 - "$bundle_path" "$ROLLBACK_STATE_PATH" "$ROLLBACK_MODE" <<'PY'
import hashlib
import json
import os
import sys
import zipfile

bundle_path = os.path.abspath(sys.argv[1])
state_path = sys.argv[2]
rollback_mode = (sys.argv[3] or "").strip().lower()
if rollback_mode == "":
    rollback_mode = "strict"


def fail(code, message):
    print(message)
    sys.exit(code)


if rollback_mode not in {"strict", "compatibility"}:
    fail(83, f"anti-rollback mode must be strict or compatibility: {rollback_mode}")


def normalize_version(version):
    if not isinstance(version, str) or version == "":
        return ("text", "")
    parts = version.split(".")
    if len(parts) > 0 and all(part.isdigit() for part in parts):
        numbers = [int(part) for part in parts]
        while len(numbers) > 0 and numbers[-1] == 0:
            numbers.pop()
        return ("numeric", numbers)
    return ("text", version)


def compare_versions(left, right):
    left_norm = normalize_version(left)
    right_norm = normalize_version(right)
    if left_norm[0] == "numeric" and right_norm[0] == "numeric":
        left_numbers = list(left_norm[1])
        right_numbers = list(right_norm[1])
        size = max(len(left_numbers), len(right_numbers))
        left_numbers.extend([0] * (size - len(left_numbers)))
        right_numbers.extend([0] * (size - len(right_numbers)))
        if left_numbers < right_numbers:
            return -1
        if left_numbers > right_numbers:
            return 1
        return 0
    if left < right:
        return -1
    if left > right:
        return 1
    return 0


try:
    archive = zipfile.ZipFile(bundle_path)
except Exception:
    sys.exit(20)

with archive:
    try:
        manifest_bytes = archive.read("manifest.json")
    except KeyError:
        fail(30, "manifest.json")

try:
    manifest_text = manifest_bytes.decode("utf-8")
except UnicodeDecodeError:
    fail(31, "manifest.json must be UTF-8")

try:
    manifest = json.loads(manifest_text)
except json.JSONDecodeError as err:
    fail(31, f"manifest.json invalid JSON at line {err.lineno} column {err.colno}")

if not isinstance(manifest, dict):
    fail(32, "manifest must be object")

cell_id = manifest.get("id")
cell_version = manifest.get("version")
if not isinstance(cell_id, str) or cell_id == "":
    fail(32, "manifest.id must be non-empty string")
if not isinstance(cell_version, str) or cell_version == "":
    fail(32, "manifest.version must be non-empty string")

with open(bundle_path, "rb") as fh:
    bundle_hash = hashlib.sha256(fh.read()).hexdigest()

state = {"version": 1, "entries": {}}
if os.path.exists(state_path):
    try:
        with open(state_path, "r", encoding="utf-8") as fh:
            state = json.load(fh)
    except Exception:
        fail(81, "anti-rollback state unreadable")

if not isinstance(state, dict):
    fail(81, "anti-rollback state invalid")

entries = state.get("entries")
if entries is None:
    entries = {}
if not isinstance(entries, dict):
    fail(81, "anti-rollback entries invalid")

record = entries.get(cell_id)
trusted_version = None
trusted_bundle_hash = None
if record is not None:
    if not isinstance(record, dict):
        fail(81, f"anti-rollback record invalid for {cell_id}")
    trusted_version = record.get("trusted_version")
    trusted_bundle_hash = record.get("trusted_bundle_hash")
    if not isinstance(trusted_version, str) or trusted_version == "":
        fail(81, f"anti-rollback trusted_version invalid for {cell_id}")
    if not isinstance(trusted_bundle_hash, str) or trusted_bundle_hash == "":
        fail(81, f"anti-rollback trusted_bundle_hash invalid for {cell_id}")

if trusted_version is not None:
    version_cmp = compare_versions(cell_version, trusted_version)
    if version_cmp < 0:
        if rollback_mode == "strict":
            fail(
                80,
                f"rollback detected for {cell_id}: candidate version {cell_version} is older than trusted {trusted_version}",
            )
        print(
            json.dumps(
                {
                    "mode": rollback_mode,
                    "cell_id": cell_id,
                    "candidate_version": cell_version,
                    "trusted_version": trusted_version,
                    "candidate_bundle_hash": bundle_hash,
                    "trusted_bundle_hash": trusted_bundle_hash,
                    "decision": "allowed_compatibility_mode",
                },
                sort_keys=True,
                separators=(",", ":"),
            )
        )
        sys.exit(0)

entries[cell_id] = {
    "trusted_version": cell_version,
    "trusted_bundle_hash": bundle_hash,
}
state["entries"] = entries
state["version"] = 1

state_dir = os.path.dirname(state_path)
if state_dir != "":
    os.makedirs(state_dir, exist_ok=True)
tmp_path = f"{state_path}.tmp"
try:

  validation_output=$(python3 - "$bundle_path" <<'PY'
import sys
import zipfile
from stat import S_ISLNK

bundle = sys.argv[1]
MAX_FILE_COUNT = 128
MAX_PER_FILE_UNCOMPRESSED_BYTES = 1024 * 1024
MAX_TOTAL_UNCOMPRESSED_BYTES = 4 * 1024 * 1024
MAX_COMPRESSION_RATIO = 100

try:
    archive = zipfile.ZipFile(bundle)
except Exception:
    sys.exit(20)

with archive:
    entries = archive.infolist()
    if len(entries) > MAX_FILE_COUNT:
        print(f"{len(entries)}>{MAX_FILE_COUNT}")
        sys.exit(24)

    seen = set()
    total_uncompressed = 0
    for info in entries:
        raw = info.filename
        path = raw.replace("\\", "/")
        mode = (info.external_attr >> 16) & 0xFFFF
        file_size = int(info.file_size)
        compressed_size = int(info.compress_size)

        if file_size > MAX_PER_FILE_UNCOMPRESSED_BYTES:
            print(f"{raw}:{file_size}>{MAX_PER_FILE_UNCOMPRESSED_BYTES}")
            sys.exit(25)

        total_uncompressed += file_size
        if total_uncompressed > MAX_TOTAL_UNCOMPRESSED_BYTES:
            print(f"{total_uncompressed}>{MAX_TOTAL_UNCOMPRESSED_BYTES}")
            sys.exit(26)

        if file_size > 0:
            if compressed_size <= 0:
                print(f"{raw}:{file_size}/{compressed_size}")
                sys.exit(27)
            if (file_size / compressed_size) > MAX_COMPRESSION_RATIO:
                print(f"{raw}:{file_size}/{compressed_size}>{MAX_COMPRESSION_RATIO}")
                sys.exit(27)

        if S_ISLNK(mode):
            print(raw)
            sys.exit(23)

        if path.startswith("/"):
            print(raw)
            sys.exit(21)

        if len(path) >= 2 and path[1] == ":" and path[0].isalpha():
            print(raw)
            sys.exit(21)

        parts = []
        for segment in path.split("/"):
            if segment == "" or segment == ".":
                continue
            if segment == "..":
                if not parts:
                    print(raw)
                    sys.exit(21)
                parts.pop()
                continue
            parts.append(segment)

        normalized = "/".join(parts)
        if normalized == "":
            continue

        if normalized in seen:
            print(normalized)
            sys.exit(22)

        seen.add(normalized)

validate_verifier_pack() {
  bundle_path="$1"

  set +e
  validation_output=$(python3 - "$bundle_path" <<'PY'
import json
import re
import sys
import zipfile

bundle = sys.argv[1]
SUPPORTED_COMPARISON_MODES = {
    "canonical_json",
    "exact_bytes",
    "regex",
    "numeric_tolerance",
}


def fail(code, message):
    print(message)
    sys.exit(code)


def canonical_json(value):
    return json.dumps(value, sort_keys=True, separators=(",", ":"), ensure_ascii=False)


def to_exact_bytes(value):
    if isinstance(value, str):
        return value.encode("utf-8")
    return json.dumps(value, sort_keys=False, separators=(",", ":"), ensure_ascii=False).encode("utf-8")


def normalize_float_tolerance(value, label):
    if value is None:
        return None
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        fail(42, f"{label} must be a non-negative number")
    if value < 0:
        fail(42, f"{label} must be non-negative")
    return float(value)


def numeric_tolerance_equal(produced, expected, tolerance):
    if isinstance(produced, bool) or isinstance(expected, bool):
        return produced == expected
    if isinstance(produced, (int, float)) and isinstance(expected, (int, float)):
        return abs(float(produced) - float(expected)) <= tolerance
    if isinstance(produced, dict) and isinstance(expected, dict):
        if set(produced.keys()) != set(expected.keys()):
            return False
        for key in produced:
            if not numeric_tolerance_equal(produced[key], expected[key], tolerance):
                return False
        return True
    if isinstance(produced, list) and isinstance(expected, list):
        if len(produced) != len(expected):
            return False
        for produced_item, expected_item in zip(produced, expected):
            if not numeric_tolerance_equal(produced_item, expected_item, tolerance):
                return False
        return True
    return produced == expected


def regex_match(produced, expected, label):
    if not isinstance(expected, str):
        fail(42, f"{label} regex mode expected_output must be string pattern")
    candidate = produced if isinstance(produced, str) else canonical_json(produced)
    try:
        return re.search(expected, candidate) is not None
    except re.error as err:
        fail(42, f"{label} invalid regex pattern: {err}")


def validate_type(value, expected_type):
    if expected_type == "object":
        return isinstance(value, dict)
    if expected_type == "array":
        return isinstance(value, list)
    if expected_type == "string":
        return isinstance(value, str)
    if expected_type == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    if expected_type == "number":
        return (isinstance(value, int) and not isinstance(value, bool)) or isinstance(value, float)
    if expected_type == "boolean":
        return isinstance(value, bool)
    if expected_type == "null":
        return value is None
    return True


def schema_check(value, schema, path):
    if not isinstance(schema, dict):
        return None

    schema_type = schema.get("type")
    if isinstance(schema_type, str):
        if not validate_type(value, schema_type):
            return f"{path} expected type {schema_type}"

    if schema_type == "object" and isinstance(value, dict):
        required = schema.get("required", [])
        if isinstance(required, list):
            for key in required:
                if isinstance(key, str) and key not in value:
                    return f"{path}.{key} missing"

        properties = schema.get("properties", {})
        if isinstance(properties, dict):
            for key, sub_schema in properties.items():
                if key in value:
                    err = schema_check(value[key], sub_schema, f"{path}.{key}")
                    if err:
                        return err

    if schema_type == "array" and isinstance(value, list):
        items = schema.get("items")
        if isinstance(items, dict):
            for idx, item in enumerate(value):
                err = schema_check(item, items, f"{path}[{idx}]")
                if err:
                    return err

    return None


def load_json_file(archive, path, missing_code, invalid_code, missing_label, invalid_label):
    try:
        file_bytes = archive.read(path)
    except KeyError:
        fail(missing_code, missing_label)

    try:
        file_text = file_bytes.decode("utf-8")
    except UnicodeDecodeError:
        fail(invalid_code, f"{path} must be UTF-8")

    try:
        return json.loads(file_text)
    except json.JSONDecodeError as err:
        fail(invalid_code, f"{invalid_label} invalid JSON at line {err.lineno} column {err.colno}")


def resolve_case_comparison(case, label, default_mode, default_float_tolerance):
    mode = default_mode
    float_tolerance = default_float_tolerance

    comparison = case.get("comparison")
    if comparison is not None:
        if not isinstance(comparison, dict):
            fail(42, f"{label}.comparison must be object")
        if "mode" in comparison:
            comparison_mode = comparison["mode"]
            if not isinstance(comparison_mode, str) or comparison_mode.strip() == "":
                fail(42, f"{label}.comparison.mode must be non-empty string")
            mode = comparison_mode.strip()
        if "float_tolerance" in comparison:
            float_tolerance = normalize_float_tolerance(
                comparison.get("float_tolerance"),
                f"{label}.comparison.float_tolerance",
            )
        elif "tolerance" in comparison:
            float_tolerance = normalize_float_tolerance(
                comparison.get("tolerance"),
                f"{label}.comparison.tolerance",
            )

    if "comparison_mode" in case:
        comparison_mode = case.get("comparison_mode")
        if not isinstance(comparison_mode, str) or comparison_mode.strip() == "":
            fail(42, f"{label}.comparison_mode must be non-empty string")
        mode = comparison_mode.strip()

    if "float_tolerance" in case:
        float_tolerance = normalize_float_tolerance(
            case.get("float_tolerance"),
            f"{label}.float_tolerance",
        )

    if mode not in SUPPORTED_COMPARISON_MODES:
        fail(42, f"{label} comparison mode unsupported: {mode}")
    if mode == "numeric_tolerance" and float_tolerance is None:
        fail(42, f"{label} numeric_tolerance requires float_tolerance")

    return {
        "mode": mode,
        "float_tolerance": float_tolerance,
    }


def load_verifier_cases_v1(archive, default_mode, default_float_tolerance):
    tests = load_json_file(
        archive,
        "verifier/tests.json",
        40,
        41,
        "verifier/tests.json",
        "verifier/tests.json",
    )
    if not isinstance(tests, list) or len(tests) == 0:
        fail(42, "verifier/tests.json must be a non-empty array")
    loaded = []
    for idx, case in enumerate(tests):
        label = f"verifier/tests.json case[{idx}]"
        if not isinstance(case, dict):
            fail(42, f"{label} must be an object")
        if "input" not in case:
            fail(42, f"{label}.input missing")
        if "expected_output" not in case:
            fail(42, f"{label}.expected_output missing")
        comparison = resolve_case_comparison(case, label, default_mode, default_float_tolerance)
        loaded.append(
            {
                "label": label,
                "input": case["input"],
                "expected_output": case["expected_output"],
                "comparison": comparison,
            }
        )
    return loaded


def load_verifier_cases_v2(archive, default_mode, default_float_tolerance):
    try:
        lines_text = archive.read("verifier/cases.jsonl").decode("utf-8")
    except KeyError:
        fail(40, "verifier/cases.jsonl")
    except UnicodeDecodeError:
        fail(41, "verifier/cases.jsonl must be UTF-8")

    loaded = []
    found_line = False
    for idx, raw_line in enumerate(lines_text.splitlines(), start=1):
        if raw_line.strip() == "":
            continue
        found_line = True
        label = f"verifier/cases.jsonl line {idx}"
        try:
            case = json.loads(raw_line)
        except json.JSONDecodeError as err:
            fail(42, f"{label} invalid JSON at line {err.lineno} column {err.colno}")
        if not isinstance(case, dict):
            fail(42, f"{label} must be an object")
        if "input" not in case:
            fail(42, f"{label}.input missing")

        expected_path = None
        for key in ("expected_path", "expected_output_path", "expected_file"):
            value = case.get(key)
            if isinstance(value, str) and value.strip() != "":
                expected_path = value.strip()
                break
        if expected_path is None:
            case_id = case.get("id")
            if isinstance(case_id, str) and case_id.strip() != "":
                expected_path = f"verifier/expected/{case_id.strip()}.json"
        if expected_path is None:
            fail(42, f"{label} expected output reference missing")

        if expected_path.startswith("verifier/expected/"):
            expected_full_path = expected_path
        else:
            expected_full_path = f"verifier/expected/{expected_path.lstrip('/')}"

        expected_output = load_json_file(
            archive,
            expected_full_path,
            40,
            41,
            expected_full_path,
            expected_full_path,
        )
        comparison = resolve_case_comparison(case, label, default_mode, default_float_tolerance)
        loaded.append(
            {
                "label": label,
                "input": case["input"],
                "expected_output": expected_output,
                "comparison": comparison,
            }
        )

    if not found_line:
        fail(42, "verifier/cases.jsonl must contain at least one case line")
    return loaded


try:
    archive = zipfile.ZipFile(bundle)
except Exception:
    sys.exit(20)

with archive:
    manifest = load_json_file(
        archive,
        "manifest.json",
        30,
        31,
        "manifest.json",
        "manifest.json",
    )
    contracts = manifest.get("contracts")
    if not isinstance(contracts, dict):
        fail(32, "manifest.contracts must be object")

    input_schema_path = contracts.get("input_schema_path")
    output_schema_path = contracts.get("output_schema_path")
    if not isinstance(input_schema_path, str) or input_schema_path == "":
        fail(32, "manifest.contracts.input_schema_path must be non-empty string")
    if not isinstance(output_schema_path, str) or output_schema_path == "":
        fail(32, "manifest.contracts.output_schema_path must be non-empty string")

    input_schema = load_json_file(
        archive,
        input_schema_path,
        46,
        47,
        input_schema_path,
        input_schema_path,
    )
    output_schema = load_json_file(
        archive,
        output_schema_path,
        46,
        47,
        output_schema_path,
        output_schema_path,
    )

    verifier = manifest.get("verifier")
    if not isinstance(verifier, dict):
        fail(32, "manifest.verifier must be object")
    default_mode = "canonical_json"
    default_float_tolerance = None

    verifier_comparison = verifier.get("comparison")
    if verifier_comparison is not None:
        if not isinstance(verifier_comparison, dict):
            fail(42, "manifest.verifier.comparison must be object")
        if "mode" in verifier_comparison:
            mode_value = verifier_comparison.get("mode")
            if not isinstance(mode_value, str) or mode_value.strip() == "":
                fail(42, "manifest.verifier.comparison.mode must be non-empty string")
            default_mode = mode_value.strip()
        if "float_tolerance" in verifier_comparison:
            default_float_tolerance = normalize_float_tolerance(
                verifier_comparison.get("float_tolerance"),
                "manifest.verifier.comparison.float_tolerance",
            )

    if "float_tolerance" in verifier:
        default_float_tolerance = normalize_float_tolerance(
            verifier.get("float_tolerance"),
            "manifest.verifier.float_tolerance",
        )

    if default_mode not in SUPPORTED_COMPARISON_MODES:
        fail(42, f"manifest.verifier.comparison.mode unsupported: {default_mode}")

    names = {info.filename for info in archive.infolist() if not info.is_dir()}

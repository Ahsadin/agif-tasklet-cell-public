#!/usr/bin/env sh
set -eu

LC_ALL=C

EXIT_USAGE=2
EXIT_BUNDLE_NOT_FOUND=3
EXIT_BUNDLE_NOT_FILE=4
EXIT_BUNDLE_INVALID=5
EXIT_CONFORMANCE_REQUIRED=6

RUNNER_VERSION="runner-v0.1"
RUNNER_POLICY="policy-preset-balanced-v1"
POLICY_PRESET="balanced"
RUNNER_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$RUNNER_DIR/.." && pwd)
CONFORMANCE_STATE_PATH="${TMPDIR:-/tmp}/agif-tasklet-cell-conformance-state.json"
PERSONALIZATION_STATE_PATH="${TMPDIR:-/tmp}/agif-tasklet-cell-personalization-state.json"
ROLLBACK_STATE_PATH="${TMPDIR:-/tmp}/agif-tasklet-cell-rollback-state.json"
ROLLBACK_MODE="${AGIF_ROLLBACK_MODE:-strict}"
VALIDATE_POLICY_PATH=""
SBOM_POLICY_MODE="sbom_optional"
SBOM_OBSERVED_STATUS="not_checked"
ATTESTATION_POLICY_MODE="attestation_optional"
ATTESTATION_OBSERVED_STATUS="not_checked"
CONFORMANCE_KEY_JSON='{}'
RUN_OFFLINE_POLICY_JSON='{}'
ENFORCEMENT_REPORT_JSON='{}'

json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

emit_error() {
  code="$1"
  message="$2"
  exit_code="$3"
  escaped_message=$(json_escape "$message")
  printf '{"ok":false,"error":{"code":"%s","message":"%s"}}\n' "$code" "$escaped_message"
  exit "$exit_code"
}

emit_help() {
  printf '%s\n' '{"ok":true,"data":{"name":"cell","commands":["info","validate","test","run","learn","show-learned","reset-personalization"],"usage":["cell info <bundle>","cell validate <bundle> [--policy <json>] [--policy-preset <strict|balanced|dev>]","cell test <bundle> [--policy-preset <strict|balanced|dev>]","cell run <bundle> --input <json> [--policy-preset <strict|balanced|dev>]","cell learn --feedback <json>","cell show-learned [--json]","cell reset-personalization --cell-id <cell_id> [--dry-run]"]}}'
}

set_policy_preset() {
  preset="${1:-balanced}"
  case "$preset" in
    strict|balanced|dev)
      POLICY_PRESET="$preset"
      RUNNER_POLICY="policy-preset-${POLICY_PRESET}-v1"
      ;;
    *)
      emit_error "POLICY_PRESET_INVALID" "Policy preset must be one of: strict,balanced,dev" "$EXIT_USAGE"
      ;;
  esac
}

load_validate_policy() {
  policy_path="${1:-}"
  SBOM_POLICY_MODE="sbom_optional"
  ATTESTATION_POLICY_MODE="attestation_optional"
  SBOM_OBSERVED_STATUS="not_checked"
  ATTESTATION_OBSERVED_STATUS="not_checked"
  VALIDATE_POLICY_PATH=""

  if [ "$policy_path" = "" ]; then
    return 0
  fi

  if [ ! -e "$policy_path" ]; then
    emit_error "POLICY_NOT_FOUND" "Policy file path not found." "$EXIT_USAGE"
  fi

  if [ ! -f "$policy_path" ]; then
    emit_error "POLICY_INVALID" "Policy path must be a regular file." "$EXIT_USAGE"
  fi

  set +e
  policy_output=$(python3 - "$policy_path" <<'PY'
import json
import sys

policy_path = sys.argv[1]

try:
    with open(policy_path, "r", encoding="utf-8") as fh:
        policy = json.load(fh)
except FileNotFoundError:
    print("policy file not found")
    sys.exit(70)
except IsADirectoryError:
    print("policy path must be file")
    sys.exit(71)
except UnicodeDecodeError:
    print("policy file must be UTF-8 JSON")
    sys.exit(72)
except json.JSONDecodeError as err:
    print(f"policy JSON invalid at line {err.lineno} column {err.colno}")
    sys.exit(72)
except Exception:
    print("policy file unreadable")
    sys.exit(72)

if not isinstance(policy, dict):
    print("policy must be object")
    sys.exit(72)

sbom_mode = "sbom_optional"
if "sbom_policy" in policy:
    sbom_mode = policy["sbom_policy"]
elif isinstance(policy.get("sbom"), dict):
    sbom_obj = policy["sbom"]
    for key in ("mode", "policy", "sbom_policy"):
        if key in sbom_obj:
            sbom_mode = sbom_obj[key]
            break

attestation_mode = "attestation_optional"
if "attestation_policy" in policy:
    attestation_mode = policy["attestation_policy"]
elif isinstance(policy.get("attestation"), dict):
    att_obj = policy["attestation"]
    for key in ("mode", "policy", "attestation_policy"):
        if key in att_obj:
            attestation_mode = att_obj[key]
            break

if not isinstance(sbom_mode, str) or sbom_mode.strip() == "":
    print("sbom policy mode must be non-empty string")
    sys.exit(72)

if not isinstance(attestation_mode, str) or attestation_mode.strip() == "":
    print("attestation policy mode must be non-empty string")
    sys.exit(72)

sbom_mode = sbom_mode.strip()
if sbom_mode not in {"sbom_optional", "sbom_required"}:
    print(f"unsupported sbom policy mode: {sbom_mode}")
    sys.exit(72)

attestation_mode = attestation_mode.strip()
if attestation_mode not in {"attestation_optional", "attestation_required"}:
    print(f"unsupported attestation policy mode: {attestation_mode}")
    sys.exit(72)

print(sbom_mode)
print(attestation_mode)
PY
  )
  policy_rc=$?
  set -e

  case "$policy_rc" in
    0)
      SBOM_POLICY_MODE=$(printf '%s\n' "$policy_output" | sed -n '1p')
      ATTESTATION_POLICY_MODE=$(printf '%s\n' "$policy_output" | sed -n '2p')
      VALIDATE_POLICY_PATH="$policy_path"
      return 0
      ;;
    70)
      emit_error "POLICY_NOT_FOUND" "Policy file path not found." "$EXIT_USAGE"
      ;;
    71)
      emit_error "POLICY_INVALID" "Policy path must be a regular file." "$EXIT_USAGE"
      ;;
    72)
      emit_error "POLICY_INVALID" "Validation policy invalid: $policy_output" "$EXIT_USAGE"
      ;;
    *)
      emit_error "POLICY_INVALID" "Validation policy invalid." "$EXIT_USAGE"
      ;;
  esac
}

emit_learn() {
  feedback_json="$1"

  set +e
  learn_output=$(python3 - "$feedback_json" "$PERSONALIZATION_STATE_PATH" "$REPO_ROOT" <<'PY'
import datetime
import hashlib
import json
import os
import sys

feedback_raw = sys.argv[1]
state_path = sys.argv[2]
repo_root = os.path.abspath(sys.argv[3])

if repo_root not in sys.path:
    sys.path.insert(0, repo_root)

try:
    payload = json.loads(feedback_raw)
except json.JSONDecodeError as err:
    print(f"feedback must be valid JSON at line {err.lineno} column {err.colno}")
    sys.exit(61)

if not isinstance(payload, dict):
    print("feedback must be a JSON object")
    sys.exit(62)


def require_object(container, key, path):
    value = container.get(key)
    if not isinstance(value, dict):
        print(f"{path}.{key} must be object")
        sys.exit(62)
    return value


def require_non_empty_string(container, key, path):
    value = container.get(key)
    if not isinstance(value, str) or value == "":
        print(f"{path}.{key} must be non-empty string")
        sys.exit(62)
    return value


def require_bool(container, key, path):
    value = container.get(key)
    if not isinstance(value, bool):
        print(f"{path}.{key} must be boolean")
        sys.exit(62)
    return value


def require_positive_int(container, key, path):
    value = container.get(key)
    if isinstance(value, bool) or not isinstance(value, int) or value <= 0:
        print(f"{path}.{key} must be positive integer")
        sys.exit(62)
    return value


def identity_key(identity):
    return f"{identity['cell_id']}+{identity['cell_version']}+{identity['bundle_hash']}"


source = require_non_empty_string(payload, "source", "feedback")
if source not in {"user_correction", "user_preference", "manual"}:
    print("feedback.source must be one of: user_correction,user_preference,manual")
    sys.exit(62)

core_identity = require_object(payload, "core_identity", "feedback")
require_non_empty_string(core_identity, "cell_id", "feedback.core_identity")
require_non_empty_string(core_identity, "cell_version", "feedback.core_identity")
require_non_empty_string(core_identity, "bundle_hash", "feedback.core_identity")

event_day = payload.get("event_day")
if event_day is None:
    event_day = datetime.date.today().isoformat()
elif not isinstance(event_day, str) or event_day == "":
    print("feedback.event_day must be non-empty string when provided")
    sys.exit(62)

runner_core_identity = payload.get("runner_core_identity", core_identity)
if not isinstance(runner_core_identity, dict):
    print("feedback.runner_core_identity must be object")
    sys.exit(62)
require_non_empty_string(runner_core_identity, "cell_id", "feedback.runner_core_identity")
require_non_empty_string(runner_core_identity, "cell_version", "feedback.runner_core_identity")
require_non_empty_string(runner_core_identity, "bundle_hash", "feedback.runner_core_identity")

proposal_identity_key = identity_key(core_identity)
runner_identity_key = identity_key(runner_core_identity)
if proposal_identity_key != runner_identity_key:
    print(
        "core identity mismatch: "
        f"proposal key {proposal_identity_key} does not match runner key {runner_identity_key}"
    )
    sys.exit(63)

proposal = require_object(payload, "proposal", "feedback")
require_non_empty_string(proposal, "rule_id", "feedback.proposal")
require_non_empty_string(proposal, "rule_text", "feedback.proposal")

personalization = require_object(payload, "personalization", "feedback")
rules = personalization.get("rules")
if not isinstance(rules, list) or len(rules) == 0:
    print("feedback.personalization.rules must be a non-empty array")
    sys.exit(62)
for idx, rule in enumerate(rules):
    if not isinstance(rule, dict):
        print(f"feedback.personalization.rules[{idx}] must be object")
        sys.exit(62)
    require_non_empty_string(rule, "rule_id", f"feedback.personalization.rules[{idx}]")
    require_non_empty_string(rule, "rule_text", f"feedback.personalization.rules[{idx}]")

gate = require_object(payload, "gate", "feedback")
core_verifier_pass = require_bool(gate, "core_verifier_pass", "feedback.gate")
local_regression_pass = require_bool(gate, "local_regression_pass", "feedback.gate")
limits = require_object(gate, "limits", "feedback.gate")
proposed_state_size_bytes = require_positive_int(limits, "proposed_state_size_bytes", "feedback.gate.limits")
max_state_size_bytes = require_positive_int(limits, "max_state_size_bytes", "feedback.gate.limits")
proposed_compute_units = require_positive_int(limits, "proposed_compute_units", "feedback.gate.limits")
max_compute_units = require_positive_int(limits, "max_compute_units", "feedback.gate.limits")
max_proposals_per_day = require_positive_int(limits, "max_proposals_per_day", "feedback.gate.limits")
max_learning_compute_per_day = require_positive_int(
    limits, "max_learning_compute_per_day", "feedback.gate.limits"
)
max_snapshots = require_positive_int(limits, "max_snapshots", "feedback.gate.limits")
episodic_corrections = payload.get("episodic_corrections", [])
if episodic_corrections is None:
    episodic_corrections = []
if not isinstance(episodic_corrections, list):
    print("feedback.episodic_corrections must be array when provided")
    sys.exit(62)

if not core_verifier_pass:
    print("core verifier pack failed")
    sys.exit(64)

if not local_regression_pass:
    print("local regression pack failed")
    sys.exit(65)

if proposed_state_size_bytes > max_state_size_bytes:
    print(
        f"proposed state size {proposed_state_size_bytes} exceeds max_state_size_bytes {max_state_size_bytes}"
    )
    sys.exit(66)

if proposed_compute_units > max_compute_units:
    print(
        f"proposed compute units {proposed_compute_units} exceeds max_compute_units {max_compute_units}"
    )
    sys.exit(66)

state = {"version": 1, "records": {}}
if os.path.exists(state_path):
    try:
        with open(state_path, "r", encoding="utf-8") as fh:
            state = json.load(fh)
    except Exception:
        print("personalization state unreadable")
        sys.exit(69)

if not isinstance(state, dict):
    print("personalization state invalid")
    sys.exit(69)

records = state.get("records")
if records is None:
    records = {}
if not isinstance(records, dict):
    print("personalization records invalid")
    sys.exit(69)

record = records.get(proposal_identity_key)
if record is None:
    record = {}
if not isinstance(record, dict):
    print("personalization record invalid")
    sys.exit(69)

applied = record.get("applied")
if applied is None:
    applied = []
if not isinstance(applied, list):
    print("personalization applied history invalid")
    sys.exit(69)

snapshots = record.get("snapshots")
if snapshots is None:
    snapshots = []
if not isinstance(snapshots, list):
    print("personalization snapshots invalid")
    sys.exit(69)

daily_usage = record.get("daily_usage")
if daily_usage is None:
    daily_usage = {}
if not isinstance(daily_usage, dict):
    print("personalization daily usage invalid")
    sys.exit(69)

daily_entry = daily_usage.get(event_day)
if daily_entry is None:
    daily_entry = {"proposals": 0, "compute_units": 0}
if not isinstance(daily_entry, dict):
    print("personalization daily usage entry invalid")
    sys.exit(69)

proposals_used_today = daily_entry.get("proposals")
compute_units_used_today = daily_entry.get("compute_units")
if (
    isinstance(proposals_used_today, bool)
    or not isinstance(proposals_used_today, int)
    or proposals_used_today < 0
):
    print("personalization daily proposals count invalid")
    sys.exit(69)
if (
    isinstance(compute_units_used_today, bool)
    or not isinstance(compute_units_used_today, int)
    or compute_units_used_today < 0
):
    print("personalization daily compute count invalid")
    sys.exit(69)

if proposals_used_today + 1 > max_proposals_per_day:
    print(
        f"daily proposals {proposals_used_today + 1} exceed max_proposals_per_day {max_proposals_per_day}"
    )
    sys.exit(67)

if compute_units_used_today + proposed_compute_units > max_learning_compute_per_day:
    print(
        "daily compute units "
        f"{compute_units_used_today + proposed_compute_units} exceed max_learning_compute_per_day "
        f"{max_learning_compute_per_day}"
    )
    sys.exit(68)

episodic_written = []
if len(episodic_corrections) > 0:
    try:
        from intelligence.episodic_store import EpisodicStore
    except Exception as err:
        print(f"episodic correction write failed: episodic store unavailable: {err}")
        sys.exit(70)

    try:
        episodic_store = EpisodicStore()
        episodic_written = episodic_store.record_corrections_batch(episodic_corrections)
    except Exception as err:
        print(f"episodic correction write failed: {err}")
        sys.exit(70)

canonical_feedback = json.dumps(payload, sort_keys=True, separators=(",", ":"), ensure_ascii=False)
proposal_id = hashlib.sha256(canonical_feedback.encode("utf-8")).hexdigest()[:16]
snapshot_id = f"snap-{len(applied) + 1:04d}"

applied.append(
    {
        "proposal_id": proposal_id,
        "event_day": event_day,
        "state_size_bytes": proposed_state_size_bytes,
        "compute_units": proposed_compute_units,
    }
)

snapshots.append(
    {
        "snapshot_id": snapshot_id,
        "proposal_id": proposal_id,
        "event_day": event_day,
    }
)
if len(snapshots) > max_snapshots:
    snapshots = snapshots[-max_snapshots:]

proposals_used_today += 1
compute_units_used_today += proposed_compute_units
daily_usage[event_day] = {
    "proposals": proposals_used_today,
    "compute_units": compute_units_used_today,
}

record = {
    "active_proposal_id": proposal_id,
    "active_state_size_bytes": proposed_state_size_bytes,
    "active_rule_count": len(rules),
    "active_rules": rules,
    "applied": applied,
    "snapshots": snapshots,
    "daily_usage": daily_usage,
    "latest_limits": {
        "max_personalization_storage_bytes": max_state_size_bytes,
        "max_compute_units": max_compute_units,
        "max_learning_compute_per_day": max_learning_compute_per_day,
        "max_proposals_per_day": max_proposals_per_day,
        "max_snapshots": max_snapshots,
    },
}
records[proposal_identity_key] = record
state = {
    "version": 1,
    "records": records,
}

state_dir = os.path.dirname(state_path)
if state_dir != "":
    os.makedirs(state_dir, exist_ok=True)
tmp_path = f"{state_path}.tmp"
try:
    with open(tmp_path, "w", encoding="utf-8") as fh:
        json.dump(state, fh, sort_keys=True, separators=(",", ":"))
    os.replace(tmp_path, state_path)
except Exception:
    print("personalization state write failed")
    sys.exit(69)

result = {
    "ok": True,
    "data": {
        "command": "learn",
        "mode": "scaffold",
        "status": "applied",
        "proposal_id": proposal_id,
        "identity_key": proposal_identity_key,
        "gate": {
            "core_verifier_pass": core_verifier_pass,
            "local_regression_pass": local_regression_pass,
            "proposed_state_size_bytes": proposed_state_size_bytes,
            "max_state_size_bytes": max_state_size_bytes,
            "proposed_compute_units": proposed_compute_units,
            "max_compute_units": max_compute_units,
            "max_proposals_per_day": max_proposals_per_day,
            "max_learning_compute_per_day": max_learning_compute_per_day,
            "max_snapshots": max_snapshots,
        },
        "usage": {
            "event_day": event_day,
            "proposals_used_today": proposals_used_today,
            "compute_units_used_today": compute_units_used_today,
            "latest_snapshot_id": snapshot_id,
            "snapshots_retained": len(snapshots),
            "episodic_corrections_written": len(episodic_written),
        },
        "episodic_corrections_written": episodic_written,
        "feedback": payload,
    },
}
print(json.dumps(result, sort_keys=False, separators=(",", ":")))
PY
  )
  learn_rc=$?
  set -e

  case "$learn_rc" in
    0)
      printf '%s\n' "$learn_output"
      ;;
    61)
      emit_error "INPUT_INVALID_JSON" "Learn feedback must be valid JSON: $learn_output" "$EXIT_USAGE"
      ;;
    62)
      emit_error "LEARN_FEEDBACK_INVALID" "Learn feedback payload invalid: $learn_output" "$EXIT_USAGE"
      ;;
    63)
      emit_error "PERSONALIZATION_CORE_MISMATCH" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    64)
      emit_error "PERSONALIZATION_CORE_VERIFIER_FAILED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    65)
      emit_error "PERSONALIZATION_LOCAL_REGRESSION_FAILED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    66)
      emit_error "PERSONALIZATION_LIMIT_EXCEEDED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    67)
      emit_error "PERSONALIZATION_DAILY_PROPOSAL_LIMIT_EXCEEDED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    68)
      emit_error "PERSONALIZATION_DAILY_COMPUTE_LIMIT_EXCEEDED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    69)
      emit_error "PERSONALIZATION_STATE_WRITE_FAILED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    70)
      emit_error "EPISODIC_WRITE_REJECTED" "Learn rejected: $learn_output" "$EXIT_BUNDLE_INVALID"
      ;;
    *)
      emit_error "LEARN_EXECUTION_FAILED" "Learn execution failed." "$EXIT_BUNDLE_INVALID"
      ;;
  esac
}

emit_show_learned() {
  format_mode="$1"

  set +e
  show_output=$(python3 - "$format_mode" "$PERSONALIZATION_STATE_PATH" <<'PY'
import json
import os
import sys

format_mode = sys.argv[1]
state_path = sys.argv[2]

if format_mode not in {"text", "json"}:
    print("format must be text or json")
    sys.exit(61)

state = {"version": 1, "records": {}}
if os.path.exists(state_path):
    try:
        with open(state_path, "r", encoding="utf-8") as fh:
            state = json.load(fh)
    except Exception:
        print("personalization state unreadable")
        sys.exit(62)

if not isinstance(state, dict):
    print("personalization state invalid")
    sys.exit(62)

records = state.get("records")
if records is None:
    records = {}
if not isinstance(records, dict):
    print("personalization records invalid")
    sys.exit(62)

rows = []
plain_lines = []
for identity_key in sorted(records.keys()):
    record = records.get(identity_key)
    if not isinstance(record, dict):
        print("personalization record invalid")
        sys.exit(62)

    latest_limits = record.get("latest_limits")
    if latest_limits is None:
        latest_limits = {}
    if not isinstance(latest_limits, dict):
        print("personalization limits invalid")
        sys.exit(62)

    snapshots = record.get("snapshots")
    if snapshots is None:
        snapshots = []
    if not isinstance(snapshots, list):
        print("personalization snapshots invalid")
        sys.exit(62)

    daily_usage = record.get("daily_usage")
    if daily_usage is None:
        daily_usage = {}
    if not isinstance(daily_usage, dict):
        print("personalization daily usage invalid")
        sys.exit(62)

    applied = record.get("applied")
    if applied is None:
        applied = []
    if not isinstance(applied, list):
        print("personalization applied history invalid")
        sys.exit(62)

    active_rules = record.get("active_rules")
    if active_rules is None:
        active_rules = []
    if not isinstance(active_rules, list):
        print("personalization active rules invalid")
        sys.exit(62)
    normalized_rules = []
    for idx, rule in enumerate(active_rules):
        if not isinstance(rule, dict):
            print(f"personalization active_rules[{idx}] invalid")
            sys.exit(62)
        rule_id = rule.get("rule_id")
        rule_text = rule.get("rule_text")
        if not isinstance(rule_id, str) or rule_id == "":
            print(f"personalization active_rules[{idx}].rule_id invalid")
            sys.exit(62)
        if not isinstance(rule_text, str) or rule_text == "":
            print(f"personalization active_rules[{idx}].rule_text invalid")
            sys.exit(62)
        normalized_rules.append({"rule_id": rule_id, "rule_text": rule_text})
    normalized_rules = sorted(normalized_rules, key=lambda r: (r["rule_id"], r["rule_text"]))

    active_proposal_id = record.get("active_proposal_id")
    if active_proposal_id is not None and (not isinstance(active_proposal_id, str) or active_proposal_id == ""):
        print("personalization active_proposal_id invalid")
        sys.exit(62)

    latest_snapshot_id = None
    if len(snapshots) > 0:
        latest_snapshot = snapshots[-1]
        if not isinstance(latest_snapshot, dict):
            print("personalization snapshot entry invalid")
            sys.exit(62)
        candidate_snapshot_id = latest_snapshot.get("snapshot_id")
        if candidate_snapshot_id is not None:
            if not isinstance(candidate_snapshot_id, str) or candidate_snapshot_id == "":
                print("personalization snapshot_id invalid")
                sys.exit(62)
            latest_snapshot_id = candidate_snapshot_id

    rows.append(
        {
            "identity_key": identity_key,
            "max_personalization_storage_bytes": latest_limits.get("max_personalization_storage_bytes"),
            "max_learning_compute_per_day": latest_limits.get("max_learning_compute_per_day"),
            "max_proposals_per_day": latest_limits.get("max_proposals_per_day"),
            "max_snapshots": latest_limits.get("max_snapshots"),
            "snapshots_retained": len(snapshots),
            "active_proposal_id": active_proposal_id,
            "latest_snapshot_id": latest_snapshot_id,

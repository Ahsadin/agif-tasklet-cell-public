        json.dump(state, fh, sort_keys=True, separators=(",", ":"))
    os.replace(tmp_path, state_path)
except Exception:
    fail(82, "anti-rollback state write failed")

print(
    json.dumps(
        {
            "mode": rollback_mode,
            "cell_id": cell_id,
            "candidate_version": cell_version,
            "trusted_version": cell_version,
            "candidate_bundle_hash": bundle_hash,
            "decision": "recorded",
        },
        sort_keys=True,
        separators=(",", ":"),
    )
)
PY

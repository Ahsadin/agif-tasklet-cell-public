sbom_observed_status = sys.argv[3]
attestation_policy_mode = sys.argv[4]
attestation_observed_status = sys.argv[5]
policy_preset = sys.argv[6]


def fail(code, message):
    print(message)
    sys.exit(code)


def required_object(container, key, path):
    value = container.get(key)
    if not isinstance(value, dict):
        fail(32, f"{path}.{key} must be object")
    return value


def required_positive_int(container, key, path):
    value = container.get(key)
    if isinstance(value, bool) or not isinstance(value, int) or value <= 0:
        fail(32, f"{path}.{key} must be positive integer")
    return value


def required_sbom_mode(value):
    if not isinstance(value, str):
        fail(33, "sbom policy mode must be string")
    if value not in {"sbom_optional", "sbom_required"}:
        fail(33, f"unsupported sbom policy mode: {value}")
    return value


def required_sbom_status(value):
    if not isinstance(value, str) or value == "":
        fail(33, "sbom observed status must be non-empty string")
    return value

def required_attestation_mode(value):
    if not isinstance(value, str):
        fail(34, "attestation policy mode must be string")
    if value not in {"attestation_optional", "attestation_required"}:
        fail(34, f"unsupported attestation policy mode: {value}")
    return value

def required_attestation_status(value):
    if not isinstance(value, str) or value == "":
        fail(34, "attestation observed status must be non-empty string")
    return value

def required_policy_preset(value):
    if not isinstance(value, str):
        fail(35, "policy preset must be string")
    if value not in {"strict", "balanced", "dev"}:
        fail(35, f"unsupported policy preset: {value}")
    return value


try:
    archive = zipfile.ZipFile(bundle)
except Exception:
    sys.exit(20)

with archive:
    try:
        manifest_bytes = archive.read("manifest.json")
    except KeyError:
        fail(30, "manifest.json")

try:
    manifest_text = manifest_bytes.decode("utf-8")
except UnicodeDecodeError:
    fail(31, "manifest.json must be UTF-8")

try:
    manifest = json.loads(manifest_text)
except json.JSONDecodeError as err:
    fail(31, f"manifest.json invalid JSON at line {err.lineno} column {err.colno}")

if not isinstance(manifest, dict):
    fail(31, "manifest must be object")

runner_compat = required_object(manifest, "runner_compat", "manifest")
execution_kind = runner_compat.get("execution_kind")
if execution_kind not in {"wasi", "native"}:
    fail(32, "manifest.runner_compat.execution_kind must be one of: wasi,native")

capabilities = required_object(manifest, "capabilities", "manifest")
network_requested = capabilities.get("network")
if not isinstance(network_requested, bool):
    fail(32, "manifest.capabilities.network must be boolean")

filesystem = required_object(capabilities, "filesystem", "manifest.capabilities")
preopens = filesystem.get("preopens")
if not isinstance(preopens, list):
    fail(32, "manifest.capabilities.filesystem.preopens must be array")
for idx, item in enumerate(preopens):
    if not isinstance(item, str) or item == "":
        fail(32, f"manifest.capabilities.filesystem.preopens[{idx}] must be non-empty string")

limits = required_object(manifest, "limits", "manifest")
max_wall_ms = required_positive_int(limits, "max_wall_ms", "manifest.limits")
max_steps = required_positive_int(limits, "max_steps", "manifest.limits")
max_memory_mb = required_positive_int(limits, "max_memory_mb", "manifest.limits")
max_output_bytes = required_positive_int(limits, "max_output_bytes", "manifest.limits")
max_tool_calls = required_positive_int(limits, "max_tool_calls", "manifest.limits")

offline_level = "strong" if execution_kind == "wasi" else "none"
